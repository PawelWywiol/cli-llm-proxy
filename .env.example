# API key for authenticating requests (empty = auth disabled)
PROXY_API_KEY=

# HTTP listen port (default: 11434, Ollama-compatible)
PORT=11434

# Path to Claude Code CLI binary (default: "claude", resolved via PATH)
CLAUDE_CLI_PATH=claude

# Path to Gemini CLI binary (default: "gemini", resolved via PATH)
GEMINI_CLI_PATH=gemini

# Path to GitHub CLI binary (default: "gh", resolved via PATH)
COPILOT_CLI_PATH=gh

# Log level: trace, debug, info, warn, error, fatal (default: info)
LOG_LEVEL=info

# Set to "production" to disable pino-pretty log formatting
NODE_ENV=development
