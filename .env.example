# API key for authenticating requests (empty = auth disabled)
PROXY_API_KEY=

# HTTP listen port (default: 11434, Ollama-compatible)
PORT=11434

# Bind address (default: 127.0.0.1; compose forces 0.0.0.0 inside the container)
HOST=127.0.0.1

# --- Docker Compose (host-installed CLIs) ---
# Home dir of the host user whose CLIs/auth are mounted into the container.
HOST_HOME=/home/code
# uid:gid the container runs as — must own the mounted CLI/auth files.
HOST_UID=1000
HOST_GID=1000

# --- Adapter selection ---
# Fallback adapter for unmatched model names.
DEFAULT_ADAPTER=claude
# Enable/disable adapters (false or 0 = off).
CLAUDE_ENABLED=true
GEMINI_ENABLED=false
COPILOT_ENABLED=false

# Path to Claude Code CLI binary (default: "claude", resolved via PATH)
CLAUDE_CLI_PATH=claude

# Path to Gemini CLI binary (default: "gemini", resolved via PATH)
GEMINI_CLI_PATH=gemini

# Path to GitHub CLI binary (default: "gh", resolved via PATH)
COPILOT_CLI_PATH=gh

# Log level: trace, debug, info, warn, error, fatal (default: info)
LOG_LEVEL=info

# Serve Swagger/OpenAPI docs at /docs (default: true; set false or 0 to disable)
DOCS_ENABLED=true

# Set to "production" to disable pino-pretty log formatting
NODE_ENV=development
