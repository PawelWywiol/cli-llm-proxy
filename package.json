{
  "name": "cli-llm-proxy",
  "version": "0.1.0",
  "description": "OpenAI-compatible HTTP proxy that routes LLM requests to local CLI tools",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "node dist/server.js",
    "dev": "tsx src/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix && oxfmt src tests vitest.config.ts",
    "format": "oxfmt src tests vitest.config.ts",
    "format:check": "oxfmt --check src tests vitest.config.ts",
    "audit:deps": "audit-ci --config ./audit-ci.json",
    "ci": "pnpm typecheck && pnpm lint && pnpm format:check && pnpm test && pnpm audit:deps",
    "prepare": "lefthook install",
    "release": "standard-version",
    "release:minor": "standard-version --release-as minor",
    "release:major": "standard-version --release-as major"
  },
  "dependencies": {
    "@fastify/cors": "^11.3.0",
    "fastify": "^5.10.0",
    "fastify-plugin": "^6.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@types/node": "^26.1.1",
    "audit-ci": "^7.1.0",
    "lefthook": "^2.1.10",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "pino-pretty": "^13.1.3",
    "standard-version": "^9.5.0",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "packageManager": "pnpm@9.0.0",
  "pnpm": {
    "overrides": {
      "fast-uri": "3.1.2",
      "lodash": "4.18.1"
    }
  },
  "standard-version": {
    "header": "# Changelog\n\nAll notable changes to this project will be documented in this file.\n",
    "types": [
      {
        "type": "feat",
        "section": "Features"
      },
      {
        "type": "fix",
        "section": "Bug Fixes"
      },
      {
        "type": "chore",
        "hidden": true
      },
      {
        "type": "docs",
        "section": "Documentation"
      },
      {
        "type": "style",
        "hidden": true
      },
      {
        "type": "refactor",
        "section": "Code Refactoring"
      },
      {
        "type": "perf",
        "section": "Performance Improvements"
      },
      {
        "type": "test",
        "hidden": true
      },
      {
        "type": "build",
        "hidden": true
      },
      {
        "type": "ci",
        "hidden": true
      }
    ],
    "commitUrlFormat": "{{host}}/{{owner}}/{{repository}}/commit/{{hash}}",
    "compareUrlFormat": "{{host}}/{{owner}}/{{repository}}/compare/{{previousTag}}...{{currentTag}}"
  }
}
